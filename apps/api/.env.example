# Local/native dev (against the docker-compose.yml postgres service):
DATABASE_URL="postgresql://sts:sts_dev_password@localhost:5432/stock_taking?schema=public"

# Individual Postgres connection parts — used by docker-compose.yml (local) and
# docker-compose.prod.yml (production) to build DATABASE_URL for the app
# container. Not read directly by the API; only DATABASE_URL above is.
POSTGRES_USER=sts
POSTGRES_PASSWORD=sts_dev_password
POSTGRES_DB=stock_taking
POSTGRES_PORT=5432

JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT=3000
