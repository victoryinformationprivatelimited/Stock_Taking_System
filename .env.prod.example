# Copy this to .env when deploying docker-compose.prod.yml, or paste these
# as Environment variables in the Portainer stack editor.

# Postgres runs as its own container (service "postgres" in
# docker-compose.prod.yml) — these values configure that container AND are
# used to build the app's DATABASE_URL automatically. You don't set
# DATABASE_URL directly here; compose assembles it from these parts.
POSTGRES_USER=sts
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=stock_taking
POSTGRES_PORT=5432

# Generate strong random secrets, e.g.: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Public URL the BROWSER will use to reach the API (baked into the web build at build time).
# Use your server's public IP/domain, not "localhost" or a Docker service name.
VITE_API_BASE_URL=http://YOUR_SERVER_IP:3000/api
